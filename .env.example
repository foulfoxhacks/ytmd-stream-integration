# =============================================================================
# ytmd-stream-integration — environment configuration
# Copy this file to `.env` and fill in your own values.
# Never commit .env to git.
# =============================================================================

# --- Pear Desktop / YTMD API Server ---
# Default port for the API Server plugin is 26538.
YTMD_HOST=http://127.0.0.1:26538
# A stable client identifier this bot uses to register with YTMD.
# Pick anything unique; YTMD will remember it after the first auth approval.
YTMD_CLIENT_ID=ytmd-stream-bot
# After running `npm run auth` and approving the popup in Pear Desktop,
# paste the token printed in your terminal here.
YTMD_TOKEN=

# --- Queue rules (apply to all platforms) ---
# Per-user cooldown in seconds before they can request again.
COOLDOWN_SECONDS=60
# Reject songs longer than this many seconds (0 = no limit).
MAX_SONG_SECONDS=420
# Maximum simultaneous pending requests per user (0 = no limit).
MAX_PER_USER=2
# Comma-separated lowercase substrings; songs whose title/artist contains
# any of these are rejected. Useful for keeping out slurs, unwanted artists, etc.
BLOCKLIST=

# --- Twitch ---
# Leave TWITCH_CHANNEL blank to disable Twitch.
TWITCH_CHANNEL=
# Bot account username (can be your own account).
TWITCH_USERNAME=
# OAuth token for the bot account. Get one at https://twitchtokengenerator.com/
# (use the "Bot Chat Token" preset). Format: oauth:xxxxxxxx
TWITCH_OAUTH=

# --- YouTube Live ---
# Leave YOUTUBE_CHANNEL_ID blank to disable YouTube Live.
# Find your channel ID at https://www.youtube.com/account_advanced
YOUTUBE_CHANNEL_ID=

# --- TikFinity webhook ---
# The bot exposes an HTTP endpoint that TikFinity (or any tool) can POST to.
# Set TIKFINITY_PORT to 0 to disable.
TIKFINITY_PORT=7280
# Optional shared secret. If set, requests must include header
#   X-Webhook-Secret: <this value>
TIKFINITY_SECRET=

# --- Command names (no leading !) ---
# Standardized command set across Twitch / YouTube Live / TikFinity:
#   !play <song>   request a song
#   !revoke        remove your own last queued song
#   !skip          skip current song (allowlist only)
#   !songqueue     show what's coming up next
#   !nowplaying    show currently playing
CMD_REQUEST=play
CMD_NOWPLAYING=nowplaying
CMD_QUEUE=songqueue
CMD_SKIP=skip
CMD_REVOKE=revoke
# Comma-separated usernames (lowercase) allowed to use !skip.
# Leave empty to allow no one (skip via the YTMD UI instead).
SKIP_ALLOWLIST=
